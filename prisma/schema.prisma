generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  surname   String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
}
